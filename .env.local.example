# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic (Claude API)
CX_MATE_ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog (analytics + session recording)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Daily Digest Email (resend.com — free tier at resend.com)
RESEND_API_KEY=your-resend-api-key
DIGEST_EMAIL=your@email.com
CRON_SECRET=any-random-secret-string

# Stripe (billing)
# Get keys from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Get from: https://dashboard.stripe.com/webhooks (register /api/billing/webhook)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Create these products/prices in Stripe Dashboard, then paste the Price IDs here
STRIPE_STARTER_MONTHLY_PRICE_ID=price_your-starter-monthly-price-id
STRIPE_STARTER_ONETIME_PRICE_ID=price_your-starter-onetime-price-id
