# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic (Claude API)
CX_MATE_ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog (analytics + session recording)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Daily Digest Email (resend.com — free tier at resend.com)
RESEND_API_KEY=your-resend-api-key
DIGEST_EMAIL=your@email.com
CRON_SECRET=any-random-secret-string

# Freemius (billing — Merchant of Record)
# Get keys from: https://dashboard.freemius.com → your product → Settings
NEXT_PUBLIC_FREEMIUS_PRODUCT_ID=25475
NEXT_PUBLIC_FREEMIUS_PUBLIC_KEY=pk_your-public-key
FREEMIUS_SECRET_KEY=sk_your-secret-key
# Register webhook URL in Freemius Dashboard → Integrations → Webhooks:
#   https://your-domain.com/api/billing/webhook

# Beta Mode (invite code gate on signup)
# Set to "true" to require invite codes during signup
# Set to "false" or omit for open access
NEXT_PUBLIC_BETA_MODE=true

# Site Password Gate (HTTP Basic Auth)
# Set a password to require authentication before accessing any page
# Remove or leave empty to disable the gate
SITE_PASSWORD=your-beta-password
